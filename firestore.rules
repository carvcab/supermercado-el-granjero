rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /datos/usuarios {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /datos/roles {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
